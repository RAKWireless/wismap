# WisMAP environment — copy to `.env` and adjust. Docker Compose reads this file
# for ${VAR} interpolation. These configure API auth (spec 009); see the README
# "Authentication" section. `.env` is gitignored; this `.env.example` is the template.

# Gate the compute-bound endpoints (POST /api/v1/validate and /solve) behind auth.
#   true  — production default; requires WISMAP_SECRET_KEY + WISMAP_API_KEYS_FILE below
#   false — local dev; endpoints are open, no keys needed, a random ephemeral secret
#           is generated. Discovery/read (GET) endpoints are public either way.
WISMAP_AUTH_ENABLED=false

# Path INSIDE the container to the YAML API-keys file (a list of {key, label} entries).
# The host `data/` dir is mounted at /app/data, so create the file at
# `data/api_keys.yml` on the host (it is gitignored). Required when auth is enabled.
# Template: `data/api_keys.example.yml`. Keys are read once at boot — restart to reload.
WISMAP_API_KEYS_FILE=/app/data/api_keys.yml

# Secret that signs the SPA session cookie and derives CSRF tokens. Required when auth
# is enabled. Keep it stable so browser sessions survive restarts, and NEVER commit the
# real value. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
WISMAP_SECRET_KEY=change_this_to_a_random_string

# Log level for the wismap.* loggers (boot key-load line, per-request auth `label` on
# success, and denials). Default INFO surfaces the matched consumer label; set WARNING
# for quieter logs (denials stay visible regardless). Uncomment to override.
#WISMAP_LOG_LEVEL=INFO
